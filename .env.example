# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=grocery_db


# --- Service Connection URLs ---
# The hostname 'postgres' and 'nats' refer to docker-compose service names.
# For local development outside Docker, change to 'localhost'.
DATABASE_URL=postgresql+asyncpg://postgres:changeme@postgres:5432/grocery_db
NATS_URL=nats://nats:4222


# --- Auth Service (JWT) ---
# IMPORTANT: generate a strong random secret for production!
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_ME_WITH_A_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60


# --- Application ---
APP_ENV=development
DEBUG=false

# Default Seed Administrator Credentials (for development)
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=
